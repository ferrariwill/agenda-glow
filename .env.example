# =============================================================================
# AgendaGlow — exemplo de variáveis de ambiente
# Copie para .env e ajuste valores sensíveis antes de subir os containers.
# =============================================================================
# PORTAS RESERVADAS (isolamento cirúrgico vs WhatsApp Gateway):
#   AgendaGlow API .............. 8081  (PORT)
#   AgendaGlow Front-end .......... 8082  (FRONTEND_PORT — futuro)
#   AgendaGlow Postgres (host) .... 5435  (DB_PORT)
#   WhatsApp Gateway API .......... 8080  ← não usar aqui
#   WhatsApp Gateway Postgres ..... 5433  ← não usar aqui
#   PostgreSQL local .............. 5432  ← não usar aqui
# =============================================================================

PORT=8081
APP_BASE_URL=http://localhost:8081
APP_PUBLIC_URL=http://localhost:8081

DB_HOST=postgres-glow
DB_PORT=5435
DB_INTERNAL_PORT=5432
DB_USER=postgres
DB_PASSWORD=altere_esta_senha
DB_NAME=agenda_glow_prod

JWT_SECRET=sua_chave_secreta_jwt_de_32_bytes

WHATSAPP_GATEWAY_URL=http://localhost:8080
WHATSAPP_GATEWAY_KEY=sua_chave_do_whatsapp_gateway

FRONTEND_PORT=8082
